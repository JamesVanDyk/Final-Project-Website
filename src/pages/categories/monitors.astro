---
import '../../styles/styles.css'
import Layout from '../../layouts/Layout.astro'
import ListItem from '../../components/item.astro'
import MonitorOne from "../../assets/images/monitor-1.png"
import MonitorTwo from "../../assets/images/monitor-2.png"
import MonitorThree from "../../assets/images/monitor-3.png"
import MonitorFour from "../../assets/images/monitor-4.png"
---

<Layout>
    <main>
        <h2>Monitor</h2>
        <section>
            <ListItem
                itemName="Monitor 1"
                itemImgURL={MonitorOne.src}
                price="$20"
                itemPageURL="/Final-Project-Website/Item-pages/monitors/monitor-one"
            />
        </section>
        <section>
            <ListItem
                itemName="Monitor 2"
                itemImgURL={MonitorTwo.src}
                price="$30"
                itemPageURL="/Final-Project-Website/Item-pages/monitors/monitor-two"
            />
        </section>
        <section>
            <ListItem
                itemName="Monitor 3"
                itemImgURL={MonitorThree.src}
                price="$40"
                itemPageURL="/Final-Project-Website/Item-pages/monitors/monitor-three"
            />
        </section>
        <section>
            <ListItem
                itemName="Monitor 4"
                itemImgURL={MonitorFour.src}
                price="$50"
                itemPageURL="/Final-Project-Website/Item-pages/monitors/monitor-four"
            />
        </section>
    </main>
</Layout>
