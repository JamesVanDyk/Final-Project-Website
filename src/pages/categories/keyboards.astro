---
import '../../styles/styles.css'
import Layout from '../../layouts/Layout.astro'
import ListItem from '../../components/item.astro'
import KeyboardOne from "../../assets/images/keyboard-1.png"
import KeyboardTwo from "../../assets/images/keyboard-2.png"
import KeyboardThree from "../../assets/images/keyboard-3.png"
import KeyboardFour from "../../assets/images/keyboard-4.png"
---
<Layout>
    <main>
        <h2>Keyboards</h2>
        <section>
            <ListItem
                itemName="Keyboard 1"
                itemImgURL={KeyboardOne.src}
                price="$20"
                itemPageURL="/Final-Project-Website/Item-pages/keyboards/keyboard-one"
            />
        </section>
        <section>
            <ListItem
                itemName="Keyboard 2"
                itemImgURL={KeyboardTwo.src}
                price="$30"
                itemPageURL=""
            />
        </section>
        <section>
            <ListItem
                itemName="Keyboard 3"
                itemImgURL={KeyboardThree.src}
                price="$40"
                itemPageURL=""
            />
        </section>
        <section>
            <ListItem
                itemName="Keyboard 4"
                itemImgURL={KeyboardFour.src}
                price="$50"
                itemPageURL=""
            />
        </section>
    </main>
</Layout>
